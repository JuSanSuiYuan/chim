// 启语(Chim)的匹配语句和下划线默认分支示例
方言 安全

函数 主函数() {
    变量 数字 := 5
    
    匹配 数字 {
        案例 1 ->
            打印("这是一")
        案例 2 ->
            打印("这是二")
        案例 3 ->
            打印("这是三")
        案例 _ ->
            打印("这是其他数字")
    }
    
    变量 字符串 := "hello"
    匹配 字符串 {
        案例 "hi" ->
            打印("打招呼")
        案例 "bye" ->
            打印("告别")
        案例 _ ->
            打印("未知的字符串")
    }
}