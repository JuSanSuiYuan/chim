// 启语(Chim)的数组和映射示例
方言 安全

函数 主函数() {
    // 数组示例
    变量 数字数组 := [1, 2, 3, 4, 5]
    打印("数组长度:", 数字数组的长度)
    打印("第一个元素:", 数字数组[0])
    
    // 映射示例
    变量 人员信息 := {
        "姓名": "张三",
        "年龄": 25,
        "城市": "北京"
    }
    打印("姓名:", 人员信息["姓名"])
    打印("年龄:", 人员信息["年龄"])
    
    // 嵌套示例
    变量 学生列表 :=
        {"学号": 1, "姓名": "李四", "成绩": 90},
        {"学号": 2, "姓名": "王五", "成绩": 85}
    ]
    打印("第二个学生姓名:", 学生列表[1]["姓名"])
    打印("第二个学生成绩:", 学生列表[1]["成绩"])
}