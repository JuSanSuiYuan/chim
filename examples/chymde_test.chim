# ChymDE演示程序
# 展示Wayland和ChymDE核心功能

struct Window:
    标题: 字符串
    宽度: 整数
    高度: 整数

fn 创建窗口(标题: 字符串, w: 整数, h: 整数) -> Window:
    令 窗口 := Window()
    窗口.标题 = 标题
    窗口.宽度 = w
    窗口.高度 = h
    返回 窗口

fn 显示窗口(窗口: Window) -> 整数:
    输出("窗口:", 窗口.标题)
    输出("大小:", 窗口.宽度, 窗口.高度)
    返回 0

fn main() -> 整数:
    输出("========================================")
    输出("      ChymDE桌面环境演示")
    输出("========================================")
    
    令 窗口1 := 创建窗口("终端", 800, 600)
    令 窗口2 := 创建窗口("浏览器", 1024, 768)
    
    显示窗口(窗口1)
    显示窗口(窗口2)
    
    输出("")
    输出("ChymDE功能:")
    输出("✓ Wayland支持")
    输出("✓ 窗口管理")
    输出("✓ Linux兼容")
    
    返回 0
