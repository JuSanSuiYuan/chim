    输出("")
    输出("╔════════════════════════════════════════╗")
    输出("║                                        ║")
    输出("║          欢迎使用 ChymDE !              ║")
    输出("║                                        ║")
    输出("║  功能特性:                              ║")
    输出("║  • Wayland原生合成器                    ║")
    输出("║  • 类似Cinnamon的用户界面               ║")
    输出("║  • Linux应用兼容                        ║")
    输出("║  • 现代化窗口管理                       ║")
    输出("║  • 可定制主题系统                       ║")
    输出("║                                        ║")
    输出("║  快捷键:                                ║")
    输出("║  • Super+D    显示桌面                  ║")
    输出("║  • Super+L    锁定屏幕                  ║")
    输出("║  • Super+Tab  切换窗口                  ║")
    输出("║  • Ctrl+Alt+T 打开终端                  ║")
    输出("║                                        ║")
    输出("╚════════════════════════════════════════╝")
    输出("")
    
    返回 0
